# ─── Core ────────────────────────────────────────────────────────────────────
PORT=3000
# Required. Use a long random string (e.g. `openssl rand -hex 32`). App exits if unset.
JWT_SECRET=change-this-to-a-long-random-string-in-production
# Public base URL of the app — used for CORS origin and generated links.
APP_URL=https://reloxy.tech

# ─── Database (Turso / libSQL) ───────────────────────────────────────────────
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Admin ───────────────────────────────────────────────────────────────────
# This email is granted the 'admin' role on signup.
ADMIN_EMAIL=

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://reloxy.tech/api/auth/google/callback

# ─── Telegram (optional) ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set to "false" on extra instances so only ONE process long-polls (avoids 409s).
TELEGRAM_POLLING=true

# RollyPay billing
ROLLYPAY_API_KEY=rpk_live_xxx
ROLLYPAY_SIGNING_SECRET=xxx

# AI — любой OpenAI-совместимый провайдер
# OpenRouter:  AI_API_URL=https://openrouter.ai/api/v1/chat/completions
# ProxyAPI:    AI_API_URL=https://api.proxyapi.ru/openai/v1/chat/completions
# Polza/VseGPT/DeepSeek — base URL из их документации
AI_API_KEY=xxx
AI_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL=deepseek/deepseek-chat

# Email OTP (Gmail app password)
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
